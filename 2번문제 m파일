function [t1, t2] = kms_24013976_func_2(h, v0, g)
% 2번 문제: 수직으로 던져진 물체의 도달 시간 계산
% 0.5*g*t^2 - v0*t + h = 0 
    a = 0.5 * g;
    b = -v0;
    c = h;
    
    D = b^2 - 4*a*c; % 판별식
    
    % 근의 공식 적용 (시간이라 양수 2개 나옴)
    t1 = (-b - sqrt(D)) / (2*a); % 작은 값 (올라갈 때)
    t2 = (-b + sqrt(D)) / (2*a); % 큰 값 (내려올 때)
end
